<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Wallpaper permissions -->
    <uses-permission android:name="android.permission.SET_WALLPAPER" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="net.dinglisch.android.tasker.PERMISSION_RUN_TASKS" />
    <uses-permission android:name="android.permission.SET_WALLPAPER_HINTS" />

    <!-- Background timer alarms -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Display Control — device state reading -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Media access (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!-- Legacy fallback for devices below API 33 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Required for Vulkan -->
    <uses-feature android:name="android.hardware.vulkan.level" android:required="false" />
    <uses-feature android:name="android.hardware.vulkan.version" android:required="false" />

    <!-- Allow querying Tasker's content provider for variable enumeration (Android 11+) -->
    <queries>
        <package android:name="net.dinglisch.android.taskerm" />
        <package android:name="net.dinglisch.android.tasker" />
        <provider android:authorities="net.dinglisch.android.taskerm" />
        <provider android:authorities="net.dinglisch.android.tasker" />
        <provider android:authorities="net.dinglisch.android.tasker.TaskerContentProvider" />
        <provider android:authorities="net.dinglisch.android.taskerm.TaskerContentProvider" />
    </queries>

    <application
        android:name=".KLVWApplication"
        android:allowBackup="true"
        android:icon="@android:mipmap/sym_def_app_icon"
        android:label="@string/app_name"
        android:roundIcon="@android:mipmap/sym_def_app_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.KLVWWallpaper"
        android:requestLegacyExternalStorage="false">

        <!-- Main Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Live Wallpaper Service -->
        <service
            android:name=".service.KLVWallpaperService"
            android:exported="true"
            android:label="@string/wallpaper_service_label"
            android:permission="android.permission.BIND_WALLPAPER">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/wallpaper_info" />
        </service>

        <!-- Live Wallpaper Service — Lock Screen -->
        <service
            android:name=".service.KLVWallpaperServiceLock"
            android:exported="true"
            android:label="@string/wallpaper_lock_service_label"
            android:permission="android.permission.BIND_WALLPAPER">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
            </intent-filter>
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/wallpaper_info_lock" />
        </service>

        <!-- Tasker Plugin: Edit Activity -->
        <activity
            android:name=".tasker.TaskerActionEdit"
            android:exported="true"
            android:label="@string/tasker_action_label"
            android:taskAffinity=""
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="com.twofortyfouram.locale.intent.action.EDIT_SETTING" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Tasker Plugin: Fire Receiver -->
        <receiver
            android:name=".tasker.TaskerActionFire"
            android:exported="true">
            <intent-filter>
                <action android:name="com.twofortyfouram.locale.intent.action.FIRE_SETTING" />
            </intent-filter>
        </receiver>

        <!-- Direct broadcast receiver for Tasker Send Intent (supports variable substitution) -->
        <receiver
            android:name=".tasker.WallpaperIntentReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.klvw.wallpaper.SET_WALLPAPER" />
            </intent-filter>
        </receiver>

        <!-- Display Control — ScreenUnlockReceiver is registered dynamically in KLVWApplication
             (ACTION_USER_PRESENT is not deliverable to manifest receivers on Android 8+). -->
        <receiver
            android:name=".tile.ScreenUnlockReceiver"
            android:exported="false" />

        <!-- Device admin — grants watch-login policy for reliable device state reading. -->
        <receiver
            android:name=".tile.KLVWDeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- AlarmManager receiver — fires wallpaper rotation timers and reschedules on boot. -->
        <receiver
            android:name=".tile.WallpaperTimerReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.klvw.wallpaper.TIMER_FIRE" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- FileProvider for sharing Tasker task template files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- Popup overlay — launched by 3rd-party apps via com.klvw.wallpaper.POPUP intent action. -->
        <activity
            android:name=".tile.KLVWPopupActivity"
            android:exported="true"
            android:theme="@style/Theme.KLVWWallpaper.PopupOverlay"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:showWhenLocked="true">
            <intent-filter>
                <action android:name="com.klvw.wallpaper.POPUP" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Icon color picker — exported so 3rd-party apps can launch it directly. -->
        <activity
            android:name=".tile.IconColorTileConfig"
            android:exported="true"
            android:theme="@style/Theme.KLVWWallpaper.TileConfig"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:showWhenLocked="true" />

        <!-- KLVW Quick Set QS tile — sets home + lock wallpaper in one tap. -->
        <service
            android:name=".tile.KLVWQuickSetTileService"
            android:exported="true"
            android:label="@string/quick_set_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="true" />
        </service>

        <!-- Quick Set execution activity — tile tap + com.klvw.wallpaper.QUICK_SET intent.
             Executes configured action when global is ON; silently finishes when OFF. -->
        <activity
            android:name=".tile.KLVWQuickSetActivity"
            android:exported="true"
            android:theme="@style/Theme.KLVWWallpaper.PopupOverlay"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:showWhenLocked="true">
            <intent-filter>
                <action android:name="com.klvw.wallpaper.QUICK_SET" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Kill-switch confirmation / re-enable dialog — tile long press + com.klvw.wallpaper.QUICK_SET_LONG intent. -->
        <activity
            android:name=".tile.KLVWQuickSetConfirmActivity"
            android:exported="true"
            android:theme="@style/Theme.KLVWWallpaper.PopupOverlay"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:showWhenLocked="true">
            <intent-filter>
                <action android:name="com.klvw.wallpaper.QUICK_SET_LONG" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

    </application>

</manifest>
